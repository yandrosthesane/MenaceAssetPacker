<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Styles.Resources>
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SPACING SCALE (8px base)                                            -->
    <!-- xs=2, sm=4, md=8, lg=12, xl=16, 2xl=24, 3xl=32, 4xl=48             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="SpaceXs">2</x:Double>
    <x:Double x:Key="SpaceSm">4</x:Double>
    <x:Double x:Key="SpaceMd">8</x:Double>
    <x:Double x:Key="SpaceLg">12</x:Double>
    <x:Double x:Key="SpaceXl">16</x:Double>
    <x:Double x:Key="Space2xl">24</x:Double>
    <x:Double x:Key="Space3xl">32</x:Double>
    <x:Double x:Key="Space4xl">48</x:Double>

    <Thickness x:Key="PaddingXs">2</Thickness>
    <Thickness x:Key="PaddingSm">4</Thickness>
    <Thickness x:Key="PaddingMd">8</Thickness>
    <Thickness x:Key="PaddingLg">12</Thickness>
    <Thickness x:Key="PaddingXl">16</Thickness>
    <Thickness x:Key="Padding2xl">24</Thickness>

    <!-- Component-specific padding -->
    <Thickness x:Key="PaddingButton">12,8</Thickness>
    <Thickness x:Key="PaddingButtonSm">8,4</Thickness>
    <Thickness x:Key="PaddingButtonLg">16,10</Thickness>
    <Thickness x:Key="PaddingInput">8,6</Thickness>
    <Thickness x:Key="PaddingCard">16</Thickness>
    <Thickness x:Key="PaddingCardLg">24</Thickness>
    <Thickness x:Key="PaddingListItem">12,8</Thickness>
    <Thickness x:Key="PaddingTreeItem">8,6</Thickness>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- COLORS                                                              -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Primary Brand - Dark Teal -->
    <Color x:Key="ColorPrimary">#004f43</Color>
    <SolidColorBrush x:Key="BrushPrimary" Color="#004f43"/>
    <SolidColorBrush x:Key="BrushPrimaryLight" Color="#8ECDC8"/>
    <SolidColorBrush x:Key="BrushPrimaryMuted" Color="#003d34"/>
    <SolidColorBrush x:Key="BrushPrimaryHover" Color="#006657"/>

    <!-- Secondary Brand - Maroon -->
    <Color x:Key="ColorMaroon">#410511</Color>
    <SolidColorBrush x:Key="BrushMaroon" Color="#410511"/>
    <SolidColorBrush x:Key="BrushMaroonHover" Color="#5a0717"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="BrushSuccess" Color="#22c55e"/>
    <SolidColorBrush x:Key="BrushWarning" Color="#c89b3c"/>
    <SolidColorBrush x:Key="BrushWarningBg" Color="#3d2e00"/>
    <SolidColorBrush x:Key="BrushError" Color="#ef4444"/>
    <SolidColorBrush x:Key="BrushErrorMuted" Color="#FF8888"/>
    <SolidColorBrush x:Key="BrushInfo" Color="#8ECDC8"/>

    <!-- Backgrounds - Standardized for panels -->
    <Color x:Key="ColorBgBase">#0A0A0A</Color>
    <Color x:Key="ColorBgSurface">#1A1A1A</Color>
    <Color x:Key="ColorBgElevated">#252525</Color>
    <SolidColorBrush x:Key="BrushBgBase" Color="#0A0A0A"/>
    <SolidColorBrush x:Key="BrushBgSurface" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="BrushBgElevated" Color="#252525"/>
    <SolidColorBrush x:Key="BrushBgInput" Color="#2A2A2A"/>

    <!-- Panel backgrounds (left panel darker, right panel lighter) -->
    <SolidColorBrush x:Key="BrushPanelLeft" Color="#141414"/>
    <SolidColorBrush x:Key="BrushPanelRight" Color="#1A1A1A"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BrushBorder" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="BrushBorderLight" Color="#3E3E3E"/>
    <SolidColorBrush x:Key="BrushBorderPrimary" Color="#004f43"/>

    <!-- Text -->
    <SolidColorBrush x:Key="BrushTextPrimary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="BrushTextMuted" Color="#666666"/>

    <!-- Destructive -->
    <SolidColorBrush x:Key="BrushDestructive" Color="#410511"/>
    <SolidColorBrush x:Key="BrushDestructiveHover" Color="#5a0717"/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- CORNER RADII                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusMd">8</CornerRadius>
    <CornerRadius x:Key="RadiusLg">12</CornerRadius>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ICONS (Fluent-style white icons for tree views)                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Folder icon - 16x16 viewbox -->
    <StreamGeometry x:Key="IconFolder">M2 4.5A2.5 2.5 0 014.5 2h3.172a2 2 0 011.414.586l.828.828a1 1 0 00.708.293H14.5A2.5 2.5 0 0117 6.207V13.5a2.5 2.5 0 01-2.5 2.5h-10A2.5 2.5 0 012 13.5v-9z</StreamGeometry>

    <!-- Code function icon - 16x16 viewbox -->
    <StreamGeometry x:Key="IconFunction">M4.708 5.578L2.061 8.224l2.647 2.647.708-.707L3.475 8.224l1.94-1.94-.707-.706zm6.584 0l-.707.706 1.94 1.94-1.94 1.94.707.707 2.647-2.647-2.647-2.646zM8.293 3.5l-1.586 9 .986.174 1.586-9-.986-.174z</StreamGeometry>

    <!-- Event/lightning icon - 16x16 viewbox -->
    <StreamGeometry x:Key="IconEvent">M9 2L4 9h4l-1 5 5-7H8l1-5z</StreamGeometry>

    <!-- Target/crosshair icon - for interceptors - 16x16 viewbox -->
    <StreamGeometry x:Key="IconTarget">M8 1a7 7 0 100 14A7 7 0 008 1zm0 12A5 5 0 118 3a5 5 0 010 10zm0-8a3 3 0 100 6 3 3 0 000-6zm0 4a1 1 0 110-2 1 1 0 010 2z</StreamGeometry>

    <!-- Brush colors for icons -->
    <SolidColorBrush x:Key="BrushIconDefault" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="BrushIconFunction" Color="#3B7DD8"/>
    <SolidColorBrush x:Key="BrushIconEvent" Color="#8B5CF6"/>
    <SolidColorBrush x:Key="BrushIconInterceptor" Color="#004f43"/>
  </Styles.Resources>

</Styles>
