  "damage_formulas": {
    "base_damage": {
      "formula": "BaseDamage = Damage * Clamped(DamageMult)",
      "notes": "DamageMult is clamped to >= 0. Multiple multipliers stack additively via AddMult."
    },

    "damage_with_dropoff": {
      "formula": "FinalDamage = (BaseDamage + DamageDropoff * tileDistance) * Clamped(DamageDropoffMult)",
      "notes": "DamageDropoff is typically NEGATIVE for damage reduction at range."
    },

    "full_damage_calculation": {
      "formula": "TotalDamage = (BaseDamage + DropoffDamage + %MaxHP + %CurrentHP + PerElementDamage) * CoverMult * (IsCrit ? CritDamage : 1.0)",
      "source": "Skill$$FillDamageInfo",
      "steps": [
        "1. Calculate base damage from weapon/skill",
        "2. Add damage dropoff based on range from ideal",
        "3. Add %MaxHP bonus: targetMaxHP * DamagePctMaxHitpoints (min DamagePctMaxHitpointsMin)",
        "4. Add %CurrentHP bonus: targetCurrentHP * DamagePctCurrentHitpoints (min DamagePctCurrentHitpointsMin)",
        "5. Add per-element bonus: elementCount * DamagePerElement",
        "6. Apply cover reduction multiplier (from target's cover)",
        "7. Roll for crit and apply multiplier if successful",
        "8. Clamp to >= 0"
      ]
    },

    "armor_penetration": {
      "formula": "EffectiveAP = (ArmorPenetration + APDropoff * distance) * Clamped(APMult)",
      "interaction": "If EffectiveAP >= TargetArmor, attack penetrates. Otherwise damage may be reduced."
    },

    "armor_durability_damage": {
      "formula": "ArmorDmg = (DamageToArmorDurability + Dropoff * distance) * Clamped(Mult) * CoverMult",
      "notes": "Reduces target's armor durability, eventually destroying armor plates."
    },

    "multiplier_stacking": {
      "function": "FloatExtensions.AddMult",
      "formula": "currentMult += (newMult - 1.0)",
      "example": "Base 1.0 + two 1.5x multipliers: 1.0 + 0.5 + 0.5 = 2.0x total",
      "notes": "Multipliers stack ADDITIVELY, not multiplicatively. This prevents runaway scaling."
    },

    "suppression": {
      "formula": "FinalSuppression = Suppression * Clamped(SuppressionMult)",
      "notes": "Additive to target's suppression state. States: 0=Normal, 1=Suppressed, 2=PinnedDown"
    }
  },

