  "key_discoveries": [
    {
      "finding": "Teleportation uses two patterns",
      "details": "Instant teleport via Element.TeleportTo (sets position directly) vs animated via coroutines (JetPackHandler.JumpCoroutine)"
    },
    {
      "finding": "All handlers derive from SkillEventHandler",
      "details": "Common base at offset 0x10 stores Skill reference, offset 0x18 typically stores effect data"
    },
    {
      "finding": "Effect data is ScriptableObject-based",
      "details": "Configuration stored in separate data objects, not in handlers. Handler+0x18 points to data."
    },
    {
      "finding": "JetPack flight uses dual animation curves",
      "details": "movementCurve (0x60) for XZ interpolation, heightCurve (0x70) for arc height"
    },
    {
      "finding": "Visibility updated during flight",
      "details": "JetPackHandler.UpdateVisibilityDuringFlight checks tile visibility flag (bit 0x8) to show/hide flying unit"
    },
    {
      "finding": "Charge handlers use MoveToWithSkill",
      "details": "Movement flag 5 indicates charge mode, flag 8 triggers skill application on arrival"
    },
    {
      "finding": "Target validation checks occupancy and hazards",
      "details": "Tile+0x50 must be null (unoccupied), tile+0x1c bits 0x1/0x2 must be clear (no hazards)"
    },
    {
      "finding": "Coroutine state machines handle async movement",
      "details": "JumpCoroutine uses state 0=init, 1=flying, 2=continue pattern with WaitForSeconds yields"
    }
  ],
