            "description": "Skills that MUST exist on entity for ability to be usable"
          },
          "0x60": {
            "name": "BlockingSkillsForUsability",
            "type": "List<SkillTemplate>",
            "description": "Skills that BLOCK usability when present on entity"
          },
          "0x68": {
            "name": "RequiredSkillsForVisibility",
            "type": "List<SkillTemplate>",
            "description": "Skills required for ability to be visible in UI"
          },
          "0x70": {
            "name": "BlockingSkillsForVisibility",
            "type": "List<SkillTemplate>",
            "description": "Skills that HIDE the ability when present on entity"
          }
        }
      },
      "handler_fields": {
        "0x10": {
          "name": "Skill",
          "type": "BaseSkill",
          "inherited": true,
          "description": "Reference to the skill instance this handler controls"
        },
        "0x18": {
          "name": "EffectTemplate",
          "type": "LimitUsability",
          "inherited": true,
          "description": "Reference to the effect template with configuration"
        }
      }
    },

