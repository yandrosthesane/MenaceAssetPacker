          "address": "0x1807095e0",
          "renamed_to": "LimitUsabilityHandler_IsHidden_CheckVisibilitySkills",
          "description": "Returns true if entity lacks required visibility skills OR has blocking visibility skills"
        },
        "IsUsable": {
          "address": "0x1807098b0",
          "renamed_to": "LimitUsabilityHandler_IsUsable_CheckUsabilitySkills",
          "description": "Returns true if entity has none of blocking skills OR has at least one required skill"
        }
      },
      "template_class": {
        "name": "LimitUsability",
        "constructor": "0x180709be0",
        "fields": {
          "0x58": {
            "name": "RequiredSkillsForUsability",
