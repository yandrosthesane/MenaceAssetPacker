  "system_flow": {
    "aura_application": [
      "1. EmitAura effect is created on skill owner",
      "2. EmitAuraHandler.OnMissionStarted registers OnEntitySpawned callback",
      "3. ForEachActor applies aura to existing allied actors",
      "4. When new entity spawns, OnEntitySpawned checks alliance",
      "5. If allied, creates skill from auraSkillTemplate",
      "6. Sets origin reference on ChangePropertyAuraHandler",
      "7. Adds skill to target's SkillContainer"
    ],
    "aura_update": [
      "1. ChangePropertyAuraHandler.OnUpdate called each frame",
      "2. Validates origin entity is still alive",
      "3. Calculates distance to origin via GetDistanceTo",
      "4. Iterates PropertyChange array",
      "5. Checks if property is multiplicative via IsMultProperty",
      "6. If linearFalloff enabled, scales value by distance ratio",
      "7. Calls UpdateProperty or UpdateMultProperty on target EntityProperties"
    ]
  },
