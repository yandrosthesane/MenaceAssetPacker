{
  "analysis_title": "Stun/Daze EventHandlers Analysis",
  "analysis_date": "2026-03-07",
  "binary": "Menace Tactical Game",
  "summary": "Analysis of stun, daze, and incapacitation mechanics in Menace tactical combat system. The game implements these effects through SkillEventHandlers that modify actor states, action points, and skill availability.",

  "key_discoveries": [
    {
      "discovery": "Stun System Architecture",
      "description": "Stun is implemented through two separate mechanisms: a visual stun flag (Actor+0x16C) and a logical stun flag in EntityProperties (bit 0 of +0xEC). Both are checked by Actor::IsStunned()."
    },
    {
      "discovery": "Suppression State Machine",
      "description": "Daze effects are implemented via a 3-state suppression system: 0=Normal, 1=Suppressed, 2=PinnedDown. State transitions affect action points, skill availability, and turn progression."
    },
    {
      "discovery": "SkillEventHandler Pattern",
      "description": "All status effects extend SkillEventHandler base class. Handler+0x10 = owning Skill, Handler+0x18 = effect data, Handler+0x20 = state data. Virtual methods handle lifecycle events (OnAdded, OnRemoved, OnRoundStart, OnUpdate)."
    },
    {
      "discovery": "Incapacitation via DisableSkillsHandler",
      "description": "Full incapacitation is achieved through DisableSkillsHandler which filters and disables skills matching criteria. Can optionally also disable UsableByPlayer flag."
    },
    {
      "discovery": "Morale-Based Panic State",
      "description": "MoraleState system provides another incapacitation vector: 1=Panicked (morale<=0, except commanders), 2=Shaken, 3=Steady. Panicked actors have reduced effectiveness."
    },
    {
      "discovery": "UsableWhenPinnedDown Skill Flag",
      "description": "Skills can be marked UsableWhenPinnedDown (SkillTemplate+0x115) to allow limited actions even when actor is in PinnedDown (state 2) suppression state."
    }
  ],

