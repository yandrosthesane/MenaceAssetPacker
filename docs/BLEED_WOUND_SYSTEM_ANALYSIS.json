  "system_overview": {
    "description": "The Bleed system (referred to as 'BleedOut' internally) handles wounded units on the tactical map. When a unit leader is incapacitated, they enter a bleeding out state with a countdown timer. They can be stabilized by adjacent allies using the StopBleedout skill, or they will die when the timer expires.",
    "key_components": [
      "BleedOutTileEffect - Data template defining bleed parameters",
      "BleedOutTileEffectHandler - Runtime handler managing bleed state",
      "StopBleedout/StopBleedoutHandler - Skill to stabilize bleeding units",
      "TacticalManager events - OnBleedingOut and OnStabilized delegates",
      "BaseUnitLeader - Unit state tracking (HealthStatus, bleedRounds)"
    ]
  },
