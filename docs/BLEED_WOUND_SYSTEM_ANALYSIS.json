  "event_flow": {
    "bleed_initialization": [
      "1. Unit takes lethal damage",
      "2. BleedOutTileEffect.Create() called with current round",
      "3. BleedOutTileEffectHandler constructed with startRound and template",
      "4. Handler added to tile via Tile.AddEffect()",
      "5. OnAdded() called - sets HealthStatus=1, copies baseRounds to leader+0x78",
      "6. UI icon created via UITacticalHUD.AddBleedingWorldSpaceIcon()",
      "7. Tile marked as temporarily occupied",
      "8. TacticalManager.InvokeOnBleedingOut() fires event"
    ],
    "bleed_tick": [
      "1. OnRoundStart() called each turn",
      "2. Remaining rounds = baseRounds - (currentRound - startRound)",
      "3. If remaining > 0: Update UI text, play tick sound (+0xbc)",
      "4. If remaining <= 0: Kill leader via virtual call at +0x448, remove effect",
      "5. TacticalManager.InvokeOnBleedingOut() fires with updated count",
      "6. TacticalBarksManager triggers appropriate bark"
    ],
    "stabilization": [
      "1. Adjacent ally uses StopBleedout skill",
      "2. OnVerifyTarget() confirms tile has BleedOutTileEffect",
      "3. OnUse() retrieves handler and calls StabilizeLeader()",
      "4. StabilizeLeader() sets HealthStatus=2, plays sound (+0xc4)",
      "5. UnitStatistics.TrackStabilized() records event",
      "6. Effect removed from tile",
      "7. TacticalManager.InvokeOnStabilized() fires event",
      "8. TacticalBarksManager.OnLeaderStabilized() triggers bark 0x2e"
    ],
    "mission_end": [
      "1. OnMissionPreFinished() callback fires",
      "2. If objectives succeeded: Auto-stabilize bleeding units",
      "3. If objectives failed: Kill bleeding units",
      "4. Remove tile effect in either case"
    ]
  },
