      "effectFields": {
        "applyPanic": {
          "offset": "0x58",
          "type": "int",
          "description": "If non-zero, applies panic damage (flag 0x100)"
        },
        "reduceMoraleLevel": {
          "offset": "0x5C",
          "type": "int",
          "description": "Number of morale states to reduce"
        }
      },
      "description": "Handles attack-based morale damage. Can apply panic flag and/or directly reduce morale state levels."
    },
    "ChangeMoraleHandler": {
      "address": "0x1806FDE10",
      "effectFields": {
        "applyToTarget": {
          "offset": "0x58",
          "type": "int",
          "description": "1 = apply to tile target"
        },
        "targetState": {
          "offset": "0x5C",
          "type": "int (MoraleState)",
          "description": "Target morale state (2=Shaken, 3=Steady)"
        },
        "comparisonMode": {
          "offset": "0x60",
          "type": "int",
          "values": {
            "1": "Only apply if current morale is higher",
            "2": "Only apply if current morale is lower"
          }
        }
      },
      "description": "Sets actor morale to specific state. Used for buffs/debuffs with conditional application."
    },
    "MoraleOverMaxEffectHandler": {
      "address": "0x180716860",
      "effectFields": {
        "effectSkillTemplate": {
          "offset": "0x58",
          "type": "SkillTemplate*",
          "description": "Skill to add when morale reaches max"
        }
      },
      "description": "Adds/removes a skill based on whether morale is at maximum. Used for morale-triggered buff effects."
    },
    "FilterByMoraleHandler": {
      "address": "0x1807057F0",
      "effectFields": {
        "requiredState": {
          "offset": "0x58",
          "type": "int (MoraleState)",
          "description": "Morale state required for skill to be enabled"
        }
      },
      "description": "Conditionally enables/hides skills based on actor's current morale state."
    },
    "HandleLeaderAttributesHandler": {
      "address": "0x180706C90",
      "fields": {
        "leaderAttributes": {
          "offset": "0x20",
          "type": "UnitLeaderAttributes*"
        }
      },
      "description": "Triggers leader attribute activation (trigger type 2) when morale state changes."
    }
  },

  "conditions": {
    "MoraleStateCondition": {
      "address": "0x1806D3EB0",
      "fields": {
        "comparisonMode": {
          "offset": "0x18",
          "type": "int",
          "values": {
            "0": "Equal",
            "1": "GreaterOrEqual",
            "2": "LessOrEqual"
          }
        },
        "targetState": {
          "offset": "0x1C",
          "type": "int (MoraleState)"
        }
      },
      "description": "Skill condition that checks if actor's morale state matches criteria."
    },
    "MoraleRoleRequirement": {
      "address": "0x180577050",
      "fields": {
        "compareOperation": {
          "offset": "0x10",
          "type": "CompareOperation enum"
        },
        "targetValue": {
          "offset": "0x14",
          "type": "int"
        }
      },
      "description": "Conversation requirement checking entity morale state."
    }
  },

  "coreFunctions": {
    "ApplyMorale": {
      "address": "0x1805DD240",
      "signature": "void Actor.ApplyMorale(Actor this, uint moraleFlags, float amount)",
      "behavior": [
        "Checks actor is alive and not invulnerable",
        "Checks panic immunity flag (0xEC bit 7)",
        "Filters by morale flags mask (0xA8)",
        "Multiplies amount by moraleDamageMultiplier (0xBC)",
        "Triggers SkillContainer.OnMoraleEvent for pre-processing",
        "Clamps result to [0, MoraleMax]",
        "Calls SetMorale with final value"
      ]
    },
    "SetMorale": {
      "address": "0x1805E7150",
      "signature": "void Actor.SetMorale(Actor this, float value)",
      "behavior": [
        "Validates actor state",
        "Clamps value to [0, MoraleMax]",
        "Stores at offset 0x160",
        "Updates SkillContainer",
        "If state changed from cached (0xD4):",
        "  - Handles faction switching for panic/unpanic",
        "  - Fires TacticalManager.OnMoraleStateChanged",
        "  - Tracks statistics",
        "  - Shows UI text (Panicked/Shaken)",
        "  - If entering Panicked: propagates panic to nearby allies",
        "Updates actor visual state"
      ]
    },
    "GetMoraleState": {
      "address": "0x1805DF4D0",
      "signature": "MoraleState Actor.GetMoraleState(Actor this)",
      "behavior": [
        "Calculates ratio: currentMorale / maxMorale",
        "If ratio <= 0: Panicked (1) - except commander",
        "If ratio <= threshold (~0.5): Shaken (2)",
        "Otherwise: Steady (3)",
        "Adds moraleStateModifier from unit stats",
        "Clamps result to [1, 3]"
      ]
    },
    "GetMoraleMax": {
      "address": "0x1805DF330",
      "signature": "float Actor.GetMoraleMax(Actor this)",
      "formula": "(BaseMorale + BonusMorale) * MoraleMultiplier"
    },
    "GetMoralePct": {
      "address": "0x1805DF4A0",
      "signature": "float Actor.GetMoralePct(Actor this)",
      "formula": "currentMorale / GetMoraleMax()"
    }
  },

  "moraleTriggers": {
    "OnDamageReceived": {
      "address": "0x1805E2070",
      "description": "Handles morale effects when actor takes damage",
      "effects": [
        {
          "target": "Attacker (if Actor)",
          "flag": "0x40",
          "formula": "DAT_182d8fba4 / max(DAT_182d8fb9c, attackerAccuracy)",
          "description": "Morale boost to attacker based on accuracy (higher accuracy = lower boost)"
        },
        {
          "target": "Self",
          "flag": "0x01",
          "formula": "(hpLostPct) * DAT_182d8fd78 * DAT_182d8ffa8 * attackerOutgoingMultiplier",
          "description": "Morale loss proportional to HP percentage lost"
        }
      ]
    },
    "OnDeath": {
      "address": "0x1805E2920",
      "description": "Propagates morale effects when actor dies",
      "effects": [
        {
          "target": "Enemies (not same faction)",
          "flag": "0x20",
          "formula": "DAT_182d8fba0 - (distance - 1)",
          "description": "Negative morale (fear) to nearby enemies, stronger when closer"
        },
        {
          "target": "Allies (same faction, different unit)",
          "flag": "0x04",
          "formula": "(distance - 1) - DAT_182d8ff90, capped at DAT_182d8ffb0",
          "description": "Positive morale boost for allies seeing comrade die (revenge motivation)"
        },
        {
          "target": "Allies (same unit/squad)",
          "flag": "0x04",
          "formula": "(distance - 1) - DAT_182d8fba0, negative if close",
          "description": "Can be negative (morale loss) if squad member dies nearby"
        }
      ],
      "immunity": "Unit stats 0xEC bit 8 prevents death morale propagation"
    },
    "OnElementDeath": {
      "address": "0x1805E2C70",
      "description": "Called when a single element (soldier) in a unit dies",
      "effects": [
        {
          "target": "Self",
          "flag": "0x08",
          "formula": "(DAT_182d8fb9c / elementCount) * DAT_182d8fe54",
          "description": "Morale loss scales inversely with unit size"
        },
        {
          "target": "Killer (if enemy Actor)",
          "flag": "0x10",
          "formula": "(DAT_182d8fb9c / killerElementCount) * DAT_182d8ff94",
          "description": "Morale boost to killer for each element killed"
        }
      ]
    }
  },

