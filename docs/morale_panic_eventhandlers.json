{
  "title": "Morale/Panic EventHandler System Analysis",
  "description": "Comprehensive analysis of morale and panic mechanics from Ghidra reverse engineering",
  "version": "1.1",
  "dateAnalyzed": "2026-03-07",

  "moraleStates": {
    "enum": "Menace.Tactical.MoraleState",
    "values": {
      "1": "Panicked",
      "2": "Shaken",
      "3": "Steady"
    },
    "thresholds": {
      "panicked": "0% morale (ratio <= 0)",
      "shaken": "0% < morale <= ~50% (DAT_182d8fe40 threshold)",
      "steady": "morale > ~50%"
    }
  },

  "moraleDamageFlags": {
    "description": "Bitmask flags passed to ApplyMorale to categorize damage source",
    "flags": {
      "0x01": "Direct damage received (HP loss)",
      "0x04": "Ally death (positive morale for killing enemy)",
      "0x08": "Element death (unit loses a soldier)",
      "0x10": "Kill bonus (positive morale to killer)",
      "0x20": "Enemy death nearby (negative morale for enemies)",
      "0x40": "Morale damage to attacker based on damage dealt",
      "0x100": "Panic attack flag (used by AttackMoraleHandler)"
    },
    "filtering": "Unit stats offset 0xA8 contains mask; damage only applies if (flag & mask) != 0"
  },

  "coreEvents": {
    "OnMoraleStateChanged": {
      "address": "0x1806716B0",
      "class": "Menace.Tactical.TacticalManager",
      "signature": "void InvokeOnMoraleStateChanged(TacticalManager this, Actor entity, MoraleState newState)",
      "delegateOffset": "0x1C8",
      "description": "Central event fired when any actor's morale state changes. All morale-dependent systems subscribe to this.",
      "subscribers": [
        "TacticalBarksManager.OnMoraleStateChanged",
        "HandleLeaderAttributesHandler.OnMoraleStateChanged",
        "Various skill handlers via SkillContainer.OnMoraleEvent"
      ]
    },
    "OnMoraleEvent": {
      "skillLevel": {
        "address": "0x1806E0410",
        "class": "Menace.Tactical.Skills.Skill",
        "description": "Propagates morale change to all skill handlers via vtable 0x448"
      },
      "containerLevel": {
        "address": "0x1806EB3E0",
        "class": "Menace.Tactical.Skills.SkillContainer",
        "description": "Broadcasts morale event to all active skills on an actor"
      }
    }
  },

  "actorMoraleFields": {
    "currentMorale": {
      "offset": "0x160",
      "type": "float",
      "description": "Current morale value"
    },
    "cachedMoraleState": {
      "offset": "0xD4",
      "type": "int (MoraleState)",
      "description": "Cached morale state enum value"
    },
    "isAlive": {
      "offset": "0x48 (byte)",
      "description": "Must be non-zero for morale operations"
    },
    "isInvulnerable": {
      "offset": "0x16A (byte)",
      "description": "If non-zero, morale changes are blocked"
    },
    "faction": {
      "offset": "0x4C",
      "type": "int",
      "values": {
        "1": "Player faction",
        "2": "Enemy faction"
      }
    }
  },

  "unitStatsFields": {
    "baseMorale": {
      "offset": "0xA0",
      "type": "float",
      "description": "Base maximum morale value"
    },
    "elementCount": {
      "offset": "0x10",
      "type": "int",
      "description": "Number of elements/soldiers in unit (used for element death morale scaling)"
    },
    "bonusMorale": {
      "offset": "0xAC",
      "type": "float",
      "description": "Additional morale from buffs/equipment"
    },
    "moraleMultiplier": {
      "offset": "0xB0",
      "type": "float",
      "description": "Multiplier for max morale calculation"
    },
    "outgoingMoraleMultiplier": {
      "offset": "0xB8",
      "type": "float",
      "description": "Multiplier for morale damage dealt to enemies (OnDamageReceived)"
    },
    "moraleDamageMultiplier": {
      "offset": "0xBC",
      "type": "float",
      "description": "Multiplier applied to incoming morale damage"
    },
    "moraleStateModifier": {
      "offset": "0xC0",
      "type": "int",
      "description": "Added to calculated morale state (shifts thresholds)"
    },
    "moraleFlags": {
      "offset": "0xA8",
      "type": "uint",
      "description": "Bitmask for morale damage type filtering"
    },
    "immuneToPanic": {
      "offset": "0xEC bit 7",
      "type": "bool",
      "description": "If set, actor cannot receive morale damage"
    },
    "immuneToDeathMorale": {
      "offset": "0xEC bit 8",
      "type": "bool",
      "description": "If set, death does not propagate morale effects to nearby units"
    }
  },

  "effectHandlers": {
    "AttackMoraleHandler": {
