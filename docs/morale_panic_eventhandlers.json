  "panicPropagation": {
    "description": "When an actor enters Panicked state (1), nearby allies also receive morale damage",
    "mechanism": [
      "Actor.SetMorale detects state change to Panicked",
      "Iterates all actors in TacticalManager actor list (offset 0xA8)",
      "For each ally (same faction, alive, not self, not invulnerable):",
      "  - Calculates distance via BaseTile.GetDistanceTo",
      "  - Calls ApplyMorale on ally (amount calculation unclear)"
    ],
    "immunity": "Commander unit is immune to panic state"
  },

