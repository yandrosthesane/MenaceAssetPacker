    {
      "type": "repl",
      "name": "Verify ModularVehicleWeaponTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"ModularVehicleWeaponTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify ModularVehicleWeaponTemplate.mod_weapon.heavy.cannon_long exists",
      "code": "!Menace.SDK.Templates.Find(\"ModularVehicleWeaponTemplate\", \"mod_weapon.heavy.cannon_long\").IsNull"
    },
