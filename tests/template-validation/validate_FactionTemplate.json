{
  "name": "Template Validation - FactionTemplate",
  "description": "Validates all fields can be read from FactionTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify FactionTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"FactionTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify FactionTemplate.faction.alien_wildlife exists",
      "code": "!Menace.SDK.Templates.Find(\"FactionTemplate\", \"faction.alien_wildlife\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"FactionTemplate\", \"faction.alien_wildlife\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field AlliedFactionType",
      "code": "Menace.SDK.Templates.GetProperty(\"FactionTemplate\", \"faction.alien_wildlife\", \"AlliedFactionType\") != null"
    },
    {
      "type": "repl",
      "name": "Read field EnemyFactionType",
      "code": "Menace.SDK.Templates.GetProperty(\"FactionTemplate\", \"faction.alien_wildlife\", \"EnemyFactionType\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"FactionTemplate\", \"faction.alien_wildlife\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"FactionTemplate\", \"faction.alien_wildlife\", \"Name\") != null"
    },
    {
