      "code": "Menace.SDK.Templates.GetProperty(\"FactionTemplate\", \"faction.alien_wildlife\", \"DisplayDescription\") != null"
    },
    {
      "type": "repl",
      "name": "Read field HasIcon",
      "code": "Menace.SDK.Templates.GetProperty(\"FactionTemplate\", \"faction.alien_wildlife\", \"HasIcon\") != null"
    },
    {
      "type": "repl",
      "name": "Read field IconAssetName",
      "code": "Menace.SDK.Templates.GetProperty(\"FactionTemplate\", \"faction.alien_wildlife\", \"IconAssetName\") != null"
    },
