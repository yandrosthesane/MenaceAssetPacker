      "name": "Read field DisplayTitle",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"DisplayTitle\") != null"
    },
    {
      "type": "repl",
      "name": "Read field ShortName",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"ShortName\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DisplayShortName",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"DisplayShortName\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Description",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"Description\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DisplayDescription",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"DisplayDescription\") != null"
