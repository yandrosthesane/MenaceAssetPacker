      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"TradeValue\") != null"
    },
    {
      "type": "repl",
      "name": "Read field BlackMarketMaxQuantity",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"BlackMarketMaxQuantity\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field SquaddieNames",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"SquaddieNames\") != null"
    },
    {
      "type": "repl",
      "name": "Read field SquaddieNicknames",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"SquaddieNicknames\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Title",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"Title\") != null"
    },
    {
