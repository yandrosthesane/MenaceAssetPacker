{
  "name": "Template Validation - SquaddieItemTemplate",
  "description": "Validates all fields can be read from SquaddieItemTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify SquaddieItemTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"SquaddieItemTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify SquaddieItemTemplate.squaddie.recruitment_effort_small exists",
      "code": "!Menace.SDK.Templates.Find(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Rarity",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"Rarity\") != null"
    },
    {
      "type": "repl",
      "name": "Read field MinCampaignProgress",
      "code": "Menace.SDK.Templates.GetProperty(\"SquaddieItemTemplate\", \"squaddie.recruitment_effort_small\", \"MinCampaignProgress\") != null"
    },
    {
      "type": "repl",
