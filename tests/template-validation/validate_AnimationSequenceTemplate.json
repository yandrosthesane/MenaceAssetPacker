{
  "name": "Template Validation - AnimationSequenceTemplate",
  "description": "Validates all fields can be read from AnimationSequenceTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify AnimationSequenceTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"AnimationSequenceTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify AnimationSequenceTemplate.dropship.landing exists",
      "code": "!Menace.SDK.Templates.Find(\"AnimationSequenceTemplate\", \"dropship.landing\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.landing\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field HasRandomRotation",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.landing\", \"HasRandomRotation\") != null"
    },
    {
      "type": "repl",
      "name": "Read field MinRandomAngle",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.landing\", \"MinRandomAngle\") != null"
    },
    {
      "type": "repl",
      "name": "Read field MaxRandomAngle",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.landing\", \"MaxRandomAngle\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.landing\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Prefab",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.landing\", \"Prefab\") != null"
    },
    {
      "type": "repl",
      "name": "Verify AnimationSequenceTemplate.dropship.mission_start exists",
      "code": "!Menace.SDK.Templates.Find(\"AnimationSequenceTemplate\", \"dropship.mission_start\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.mission_start\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field HasRandomRotation",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.mission_start\", \"HasRandomRotation\") != null"
    },
    {
      "type": "repl",
      "name": "Read field MinRandomAngle",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.mission_start\", \"MinRandomAngle\") != null"
    },
    {
      "type": "repl",
      "name": "Read field MaxRandomAngle",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.mission_start\", \"MaxRandomAngle\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.mission_start\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Prefab",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.mission_start\", \"Prefab\") != null"
    },
    {
      "type": "repl",
      "name": "Verify AnimationSequenceTemplate.dropship.start_in_air exists",
      "code": "!Menace.SDK.Templates.Find(\"AnimationSequenceTemplate\", \"dropship.start_in_air\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.start_in_air\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field HasRandomRotation",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.start_in_air\", \"HasRandomRotation\") != null"
    },
    {
      "type": "repl",
      "name": "Read field MinRandomAngle",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.start_in_air\", \"MinRandomAngle\") != null"
    },
    {
      "type": "repl",
      "name": "Read field MaxRandomAngle",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.start_in_air\", \"MaxRandomAngle\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.start_in_air\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Prefab",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSequenceTemplate\", \"dropship.start_in_air\", \"Prefab\") != null"
    }
  ]
}