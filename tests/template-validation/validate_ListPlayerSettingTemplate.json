{
  "name": "Template Validation - ListPlayerSettingTemplate",
  "description": "Validates all fields can be read from ListPlayerSettingTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify ListPlayerSettingTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"ListPlayerSettingTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify ListPlayerSettingTemplate.display_display_mode exists",
      "code": "!Menace.SDK.Templates.Find(\"ListPlayerSettingTemplate\", \"display_display_mode\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ListPlayerSettingTemplate\", \"display_display_mode\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field IsActive",
      "code": "Menace.SDK.Templates.GetProperty(\"ListPlayerSettingTemplate\", \"display_display_mode\", \"IsActive\") != null"
    },
    {
