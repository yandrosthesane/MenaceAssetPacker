{
  "name": "Template Validation - GlobalDifficultyTemplate",
  "description": "Validates all fields can be read from GlobalDifficultyTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify GlobalDifficultyTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"GlobalDifficultyTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify GlobalDifficultyTemplate.global_difficulty.challenging exists",
      "code": "!Menace.SDK.Templates.Find(\"GlobalDifficultyTemplate\", \"global_difficulty.challenging\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"GlobalDifficultyTemplate\", \"global_difficulty.challenging\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field PlayerSupplyMult",
      "code": "Menace.SDK.Templates.GetProperty(\"GlobalDifficultyTemplate\", \"global_difficulty.challenging\", \"PlayerSupplyMult\") != null"
    },
    {
      "type": "repl",
      "name": "Read field EnemyArmyPointsMult",
      "code": "Menace.SDK.Templates.GetProperty(\"GlobalDifficultyTemplate\", \"global_difficulty.challenging\", \"EnemyArmyPointsMult\") != null"
    },
    {
      "type": "repl",
      "name": "Read field InitialAuthority",
      "code": "Menace.SDK.Templates.GetProperty(\"GlobalDifficultyTemplate\", \"global_difficulty.challenging\", \"InitialAuthority\") != null"
    },
    {
      "type": "repl",
      "name": "Read field InitialSquaddies",
      "code": "Menace.SDK.Templates.GetProperty(\"GlobalDifficultyTemplate\", \"global_difficulty.challenging\", \"InitialSquaddies\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"GlobalDifficultyTemplate\", \"global_difficulty.challenging\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"GlobalDifficultyTemplate\", \"global_difficulty.challenging\", \"Name\") != null"
    },
