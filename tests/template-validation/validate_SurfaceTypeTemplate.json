      "code": "Menace.SDK.Templates.GetProperty(\"SurfaceTypeTemplate\", \"surface_type.dirt_road\", \"Description\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DisplayDescription",
      "code": "Menace.SDK.Templates.GetProperty(\"SurfaceTypeTemplate\", \"surface_type.dirt_road\", \"DisplayDescription\") != null"
    },
    {
      "type": "repl",
      "name": "Verify SurfaceTypeTemplate.surface_type.earth exists",
      "code": "!Menace.SDK.Templates.Find(\"SurfaceTypeTemplate\", \"surface_type.earth\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
