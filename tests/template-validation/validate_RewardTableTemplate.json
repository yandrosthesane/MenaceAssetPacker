{
  "name": "Template Validation - RewardTableTemplate",
  "description": "Validates all fields can be read from RewardTableTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify RewardTableTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"RewardTableTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify RewardTableTemplate.reward_table.constructs exists",
      "code": "!Menace.SDK.Templates.Find(\"RewardTableTemplate\", \"reward_table.constructs\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"RewardTableTemplate\", \"reward_table.constructs\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field RarityMultiplier",
      "code": "Menace.SDK.Templates.GetProperty(\"RewardTableTemplate\", \"reward_table.constructs\", \"RarityMultiplier\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"RewardTableTemplate\", \"reward_table.constructs\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Verify RewardTableTemplate.reward_table.dice exists",
      "code": "!Menace.SDK.Templates.Find(\"RewardTableTemplate\", \"reward_table.dice\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"RewardTableTemplate\", \"reward_table.dice\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field RarityMultiplier",
      "code": "Menace.SDK.Templates.GetProperty(\"RewardTableTemplate\", \"reward_table.dice\", \"RarityMultiplier\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"RewardTableTemplate\", \"reward_table.dice\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Verify RewardTableTemplate.reward_table.generic exists",
      "code": "!Menace.SDK.Templates.Find(\"RewardTableTemplate\", \"reward_table.generic\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"RewardTableTemplate\", \"reward_table.generic\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field RarityMultiplier",
      "code": "Menace.SDK.Templates.GetProperty(\"RewardTableTemplate\", \"reward_table.generic\", \"RarityMultiplier\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"RewardTableTemplate\", \"reward_table.generic\", \"m_ID\") != null"
    }
  ]
}