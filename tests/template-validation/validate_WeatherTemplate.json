{
  "name": "Template Validation - WeatherTemplate",
  "description": "Validates all fields can be read from WeatherTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify WeatherTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"WeatherTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify WeatherTemplate.weather.desert_clear exists",
      "code": "!Menace.SDK.Templates.Find(\"WeatherTemplate\", \"weather.desert_clear\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"WeatherTemplate\", \"weather.desert_clear\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DisableDustEffects",
      "code": "Menace.SDK.Templates.GetProperty(\"WeatherTemplate\", \"weather.desert_clear\", \"DisableDustEffects\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"WeatherTemplate\", \"weather.desert_clear\", \"m_ID\") != null"
    },
    {
      "type": "repl",
