{
  "name": "Template Validation - ItemListTemplate",
  "description": "Validates all fields can be read from ItemListTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify ItemListTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"ItemListTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify ItemListTemplate.item_list.initial_pack_placeholder exists",
      "code": "!Menace.SDK.Templates.Find(\"ItemListTemplate\", \"item_list.initial_pack_placeholder\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ItemListTemplate\", \"item_list.initial_pack_placeholder\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"ItemListTemplate\", \"item_list.initial_pack_placeholder\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Title",
      "code": "Menace.SDK.Templates.GetProperty(\"ItemListTemplate\", \"item_list.initial_pack_placeholder\", \"Title\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DisplayTitle",
      "code": "Menace.SDK.Templates.GetProperty(\"ItemListTemplate\", \"item_list.initial_pack_placeholder\", \"DisplayTitle\") != null"
    }
  ]
}