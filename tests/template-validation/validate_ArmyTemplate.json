{
  "name": "Template Validation - ArmyTemplate",
  "description": "Validates all fields can be read from ArmyTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify ArmyTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"ArmyTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify ArmyTemplate.army.alien_early exists",
      "code": "!Menace.SDK.Templates.Find(\"ArmyTemplate\", \"army.alien_early\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_early\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field FactionType",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_early\", \"FactionType\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_early\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field FactionTemplate",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_early\", \"FactionTemplate\") != null"
    },
    {
      "type": "repl",
      "name": "Verify ArmyTemplate.army.alien_early_reinforcements exists",
      "code": "!Menace.SDK.Templates.Find(\"ArmyTemplate\", \"army.alien_early_reinforcements\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_early_reinforcements\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field FactionType",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_early_reinforcements\", \"FactionType\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_early_reinforcements\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field FactionTemplate",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_early_reinforcements\", \"FactionTemplate\") != null"
    },
    {
      "type": "repl",
      "name": "Verify ArmyTemplate.army.alien_mid exists",
      "code": "!Menace.SDK.Templates.Find(\"ArmyTemplate\", \"army.alien_mid\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_mid\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field FactionType",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_mid\", \"FactionType\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_mid\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field FactionTemplate",
      "code": "Menace.SDK.Templates.GetProperty(\"ArmyTemplate\", \"army.alien_mid\", \"FactionTemplate\") != null"
    }
  ]
}