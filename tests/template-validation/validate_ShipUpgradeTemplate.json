{
  "name": "Template Validation - ShipUpgradeTemplate",
  "description": "Validates all fields can be read from ShipUpgradeTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify ShipUpgradeTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"ShipUpgradeTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify ShipUpgradeTemplate.base_ship exists",
      "code": "!Menace.SDK.Templates.Find(\"ShipUpgradeTemplate\", \"base_ship\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeTemplate\", \"base_ship\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field UpgradeType",
