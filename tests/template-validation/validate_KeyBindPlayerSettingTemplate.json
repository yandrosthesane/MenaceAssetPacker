{
  "name": "Template Validation - KeyBindPlayerSettingTemplate",
  "description": "Validates all fields can be read from KeyBindPlayerSettingTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify KeyBindPlayerSettingTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"KeyBindPlayerSettingTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify KeyBindPlayerSettingTemplate.dev_key_bind_cam_load_position exists",
      "code": "!Menace.SDK.Templates.Find(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_load_position\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_load_position\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Type",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_load_position\", \"Type\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Default",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_load_position\", \"Default\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_load_position\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_load_position\", \"Name\") != null"
    },
    {
      "type": "repl",
      "name": "Verify KeyBindPlayerSettingTemplate.dev_key_bind_cam_move_down exists",
      "code": "!Menace.SDK.Templates.Find(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_down\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_down\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Type",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_down\", \"Type\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Default",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_down\", \"Default\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_down\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_down\", \"Name\") != null"
    },
    {
      "type": "repl",
      "name": "Verify KeyBindPlayerSettingTemplate.dev_key_bind_cam_move_up exists",
      "code": "!Menace.SDK.Templates.Find(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_up\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_up\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Type",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_up\", \"Type\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Default",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_up\", \"Default\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_up\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"KeyBindPlayerSettingTemplate\", \"dev_key_bind_cam_move_up\", \"Name\") != null"
    }
  ]
}