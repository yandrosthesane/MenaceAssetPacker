{
  "name": "Template Validation - ShipUpgradeSlotTemplate",
  "description": "Validates all fields can be read from ShipUpgradeSlotTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify ShipUpgradeSlotTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"ShipUpgradeSlotTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify ShipUpgradeSlotTemplate.ship_upgrade_slot.armament exists",
      "code": "!Menace.SDK.Templates.Find(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.armament\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.armament\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field UpgradeType",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.armament\", \"UpgradeType\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.armament\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.armament\", \"Name\") != null"
    },
    {
      "type": "repl",
      "name": "Verify ShipUpgradeSlotTemplate.ship_upgrade_slot.electronics exists",
      "code": "!Menace.SDK.Templates.Find(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.electronics\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.electronics\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field UpgradeType",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.electronics\", \"UpgradeType\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.electronics\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.electronics\", \"Name\") != null"
    },
    {
      "type": "repl",
      "name": "Verify ShipUpgradeSlotTemplate.ship_upgrade_slot.hull exists",
      "code": "!Menace.SDK.Templates.Find(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.hull\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.hull\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field UpgradeType",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.hull\", \"UpgradeType\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.hull\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"ShipUpgradeSlotTemplate\", \"ship_upgrade_slot.hull\", \"Name\") != null"
    }
  ]
}