{
  "name": "Template Validation - AnimationSoundTemplate",
  "description": "Validates all fields can be read from AnimationSoundTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify AnimationSoundTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"AnimationSoundTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify AnimationSoundTemplate.alien_bombardier_animation_sounds exists",
      "code": "!Menace.SDK.Templates.Find(\"AnimationSoundTemplate\", \"alien_bombardier_animation_sounds\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSoundTemplate\", \"alien_bombardier_animation_sounds\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSoundTemplate\", \"alien_bombardier_animation_sounds\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Verify AnimationSoundTemplate.alien_warrior_animation_sounds exists",
      "code": "!Menace.SDK.Templates.Find(\"AnimationSoundTemplate\", \"alien_warrior_animation_sounds\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSoundTemplate\", \"alien_warrior_animation_sounds\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSoundTemplate\", \"alien_warrior_animation_sounds\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Verify AnimationSoundTemplate.construct_carrier_animation_sounds exists",
      "code": "!Menace.SDK.Templates.Find(\"AnimationSoundTemplate\", \"construct_carrier_animation_sounds\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSoundTemplate\", \"construct_carrier_animation_sounds\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"AnimationSoundTemplate\", \"construct_carrier_animation_sounds\", \"m_ID\") != null"
    }
  ]
}