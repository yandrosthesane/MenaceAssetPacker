      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify PlanetTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"PlanetTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify PlanetTemplate.planet.backbone exists",
      "code": "!Menace.SDK.Templates.Find(\"PlanetTemplate\", \"planet.backbone\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"PlanetTemplate\", \"planet.backbone\", \"name\") != null"
    },
