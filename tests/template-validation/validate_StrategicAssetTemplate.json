{
  "name": "Template Validation - StrategicAssetTemplate",
  "description": "Validates all fields can be read from StrategicAssetTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify StrategicAssetTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"StrategicAssetTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify StrategicAssetTemplate.backlines_secured exists",
      "code": "!Menace.SDK.Templates.Find(\"StrategicAssetTemplate\", \"backlines_secured\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"StrategicAssetTemplate\", \"backlines_secured\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DisableAfterMission",
      "code": "Menace.SDK.Templates.GetProperty(\"StrategicAssetTemplate\", \"backlines_secured\", \"DisableAfterMission\") != null"
    },
