      "name": "Read field Height",
      "code": "Menace.SDK.Templates.GetProperty(\"ChunkTemplate\", \"chunk_cargo_crate_2x3\", \"Height\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Type",
      "code": "Menace.SDK.Templates.GetProperty(\"ChunkTemplate\", \"chunk_cargo_crate_2x3\", \"Type\") != null"
    },
    {
      "type": "repl",
      "name": "Read field SpawnMode",
      "code": "Menace.SDK.Templates.GetProperty(\"ChunkTemplate\", \"chunk_cargo_crate_2x3\", \"SpawnMode\") != null"
    },
    {
      "type": "repl",
      "name": "Read field MaxSpawns",
      "code": "Menace.SDK.Templates.GetProperty(\"ChunkTemplate\", \"chunk_cargo_crate_2x3\", \"MaxSpawns\") != null"
    },
    {
      "type": "repl",
      "name": "Read field RandomlyRotateChildren",
      "code": "Menace.SDK.Templates.GetProperty(\"ChunkTemplate\", \"chunk_cargo_crate_2x3\", \"RandomlyRotateChildren\") != null"
    },
    {
      "type": "repl",
      "name": "Read field CoverConfig",
      "code": "Menace.SDK.Templates.GetProperty(\"ChunkTemplate\", \"chunk_cargo_crate_2x3\", \"CoverConfig\") != null"
    }
  ]
}