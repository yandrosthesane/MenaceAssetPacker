{
  "name": "Template Validation - VideoTemplate",
  "description": "Validates all fields can be read from VideoTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify VideoTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"VideoTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify VideoTemplate.video.fmzama_rogue_army_arrival exists",
      "code": "!Menace.SDK.Templates.Find(\"VideoTemplate\", \"video.fmzama_rogue_army_arrival\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"VideoTemplate\", \"video.fmzama_rogue_army_arrival\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"VideoTemplate\", \"video.fmzama_rogue_army_arrival\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Verify VideoTemplate.video.intro_scene_2_impetus exists",
      "code": "!Menace.SDK.Templates.Find(\"VideoTemplate\", \"video.intro_scene_2_impetus\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"VideoTemplate\", \"video.intro_scene_2_impetus\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"VideoTemplate\", \"video.intro_scene_2_impetus\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Verify VideoTemplate.video.intro_scene_2_impetus_part_1 exists",
      "code": "!Menace.SDK.Templates.Find(\"VideoTemplate\", \"video.intro_scene_2_impetus_part_1\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"VideoTemplate\", \"video.intro_scene_2_impetus_part_1\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"VideoTemplate\", \"video.intro_scene_2_impetus_part_1\", \"m_ID\") != null"
    }
  ]
}