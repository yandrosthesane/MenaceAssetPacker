      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"BoolPlayerSettingTemplate\", \"controls_cam_mouse_wheel_zoom\", \"Name\") != null"
    },
    {
      "type": "repl",
      "name": "Verify BoolPlayerSettingTemplate.controls_keep_skill_selected_if_still_usable exists",
      "code": "!Menace.SDK.Templates.Find(\"BoolPlayerSettingTemplate\", \"controls_keep_skill_selected_if_still_usable\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
