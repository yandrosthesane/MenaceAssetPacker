{
  "name": "Template Validation - BoolPlayerSettingTemplate",
  "description": "Validates all fields can be read from BoolPlayerSettingTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify BoolPlayerSettingTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"BoolPlayerSettingTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify BoolPlayerSettingTemplate.audio_mute_in_background exists",
      "code": "!Menace.SDK.Templates.Find(\"BoolPlayerSettingTemplate\", \"audio_mute_in_background\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"BoolPlayerSettingTemplate\", \"audio_mute_in_background\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Type",
      "code": "Menace.SDK.Templates.GetProperty(\"BoolPlayerSettingTemplate\", \"audio_mute_in_background\", \"Type\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DefaultValue",
      "code": "Menace.SDK.Templates.GetProperty(\"BoolPlayerSettingTemplate\", \"audio_mute_in_background\", \"DefaultValue\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"BoolPlayerSettingTemplate\", \"audio_mute_in_background\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"BoolPlayerSettingTemplate\", \"audio_mute_in_background\", \"Name\") != null"
    },
    {
      "type": "repl",
      "name": "Verify BoolPlayerSettingTemplate.controls_cam_mouse_wheel_zoom exists",
      "code": "!Menace.SDK.Templates.Find(\"BoolPlayerSettingTemplate\", \"controls_cam_mouse_wheel_zoom\").IsNull"
    },
    {
