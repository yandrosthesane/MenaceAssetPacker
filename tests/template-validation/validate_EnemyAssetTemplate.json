{
  "name": "Template Validation - EnemyAssetTemplate",
  "description": "Validates all fields can be read from EnemyAssetTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify EnemyAssetTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"EnemyAssetTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify EnemyAssetTemplate.enemy_asset.anti_tank_weapon_arsenal exists",
      "code": "!Menace.SDK.Templates.Find(\"EnemyAssetTemplate\", \"enemy_asset.anti_tank_weapon_arsenal\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"EnemyAssetTemplate\", \"enemy_asset.anti_tank_weapon_arsenal\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DisableAfterMission",
