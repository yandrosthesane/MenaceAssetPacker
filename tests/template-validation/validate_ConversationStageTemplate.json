{
  "name": "Template Validation - ConversationStageTemplate",
  "description": "Validates all fields can be read from ConversationStageTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify ConversationStageTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"ConversationStageTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify ConversationStageTemplate.stage.armory exists",
      "code": "!Menace.SDK.Templates.Find(\"ConversationStageTemplate\", \"stage.armory\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.armory\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.armory\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Title",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.armory\", \"Title\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DisplayTitle",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.armory\", \"DisplayTitle\") != null"
    },
    {
      "type": "repl",
      "name": "Read field BackgroundImage",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.armory\", \"BackgroundImage\") != null"
    },
    {
      "type": "repl",
      "name": "Verify ConversationStageTemplate.stage.bridge exists",
      "code": "!Menace.SDK.Templates.Find(\"ConversationStageTemplate\", \"stage.bridge\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.bridge\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.bridge\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Title",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.bridge\", \"Title\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DisplayTitle",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.bridge\", \"DisplayTitle\") != null"
    },
    {
      "type": "repl",
      "name": "Read field BackgroundImage",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.bridge\", \"BackgroundImage\") != null"
    },
    {
      "type": "repl",
      "name": "Verify ConversationStageTemplate.stage.command_room exists",
      "code": "!Menace.SDK.Templates.Find(\"ConversationStageTemplate\", \"stage.command_room\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.command_room\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.command_room\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Title",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.command_room\", \"Title\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DisplayTitle",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.command_room\", \"DisplayTitle\") != null"
    },
    {
      "type": "repl",
      "name": "Read field BackgroundImage",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationStageTemplate\", \"stage.command_room\", \"BackgroundImage\") != null"
    }
  ]
}