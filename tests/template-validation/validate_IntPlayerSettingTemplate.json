{
  "name": "Template Validation - IntPlayerSettingTemplate",
  "description": "Validates all fields can be read from IntPlayerSettingTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify IntPlayerSettingTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"IntPlayerSettingTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify IntPlayerSettingTemplate.audio_ambience_volume exists",
      "code": "!Menace.SDK.Templates.Find(\"IntPlayerSettingTemplate\", \"audio_ambience_volume\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"IntPlayerSettingTemplate\", \"audio_ambience_volume\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Type",
      "code": "Menace.SDK.Templates.GetProperty(\"IntPlayerSettingTemplate\", \"audio_ambience_volume\", \"Type\") != null"
    },
    {
      "type": "repl",
