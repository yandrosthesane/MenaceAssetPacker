{
  "name": "Template Validation - OperationDurationTemplate",
  "description": "Validates all fields can be read from OperationDurationTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify OperationDurationTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"OperationDurationTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify OperationDurationTemplate.operation_duration.long exists",
      "code": "!Menace.SDK.Templates.Find(\"OperationDurationTemplate\", \"operation_duration.long\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.long\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field OperationRewardRarityIncreasePctPerStar",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.long\", \"OperationRewardRarityIncreasePctPerStar\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.long\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.long\", \"Name\") != null"
    },
    {
      "type": "repl",
      "name": "Verify OperationDurationTemplate.operation_duration.medium exists",
      "code": "!Menace.SDK.Templates.Find(\"OperationDurationTemplate\", \"operation_duration.medium\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.medium\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field OperationRewardRarityIncreasePctPerStar",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.medium\", \"OperationRewardRarityIncreasePctPerStar\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.medium\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.medium\", \"Name\") != null"
    },
    {
      "type": "repl",
      "name": "Verify OperationDurationTemplate.operation_duration.short exists",
      "code": "!Menace.SDK.Templates.Find(\"OperationDurationTemplate\", \"operation_duration.short\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.short\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field OperationRewardRarityIncreasePctPerStar",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.short\", \"OperationRewardRarityIncreasePctPerStar\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.short\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"OperationDurationTemplate\", \"operation_duration.short\", \"Name\") != null"
    }
  ]
}