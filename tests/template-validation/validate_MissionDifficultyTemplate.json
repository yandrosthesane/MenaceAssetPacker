{
  "name": "Template Validation - MissionDifficultyTemplate",
  "description": "Validates all fields can be read from MissionDifficultyTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify MissionDifficultyTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"MissionDifficultyTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify MissionDifficultyTemplate.mission_difficulty_easy exists",
      "code": "!Menace.SDK.Templates.Find(\"MissionDifficultyTemplate\", \"mission_difficulty_easy\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionDifficultyTemplate\", \"mission_difficulty_easy\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field DifficultyType",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionDifficultyTemplate\", \"mission_difficulty_easy\", \"DifficultyType\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Skulls",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionDifficultyTemplate\", \"mission_difficulty_easy\", \"Skulls\") != null"
    },
    {
      "type": "repl",
      "name": "Read field PromotionPointsMult",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionDifficultyTemplate\", \"mission_difficulty_easy\", \"PromotionPointsMult\") != null"
    },
    {
      "type": "repl",
      "name": "Read field PlayerSupplyMult",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionDifficultyTemplate\", \"mission_difficulty_easy\", \"PlayerSupplyMult\") != null"
    },
    {
      "type": "repl",
      "name": "Read field EnemyArmyPointsMult",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionDifficultyTemplate\", \"mission_difficulty_easy\", \"EnemyArmyPointsMult\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionDifficultyTemplate\", \"mission_difficulty_easy\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionDifficultyTemplate\", \"mission_difficulty_easy\", \"Name\") != null"
    },
