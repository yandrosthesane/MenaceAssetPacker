{
  "name": "Template Validation - RagdollTemplate",
  "description": "Validates all fields can be read from RagdollTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify RagdollTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"RagdollTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify RagdollTemplate.ragdoll_alien01 exists",
      "code": "!Menace.SDK.Templates.Find(\"RagdollTemplate\", \"ragdoll_alien01\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"RagdollTemplate\", \"ragdoll_alien01\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field BloodPoolPosition",
      "code": "Menace.SDK.Templates.GetProperty(\"RagdollTemplate\", \"ragdoll_alien01\", \"BloodPoolPosition\") != null"
    },
    {
      "type": "repl",
