{
  "name": "Template Validation - DossierItemTemplate",
  "description": "Validates all fields can be read from DossierItemTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify DossierItemTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"DossierItemTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify DossierItemTemplate.dossier.pilot exists",
      "code": "!Menace.SDK.Templates.Find(\"DossierItemTemplate\", \"dossier.pilot\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"DossierItemTemplate\", \"dossier.pilot\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Rarity",
