{
  "name": "Template Validation - UnitRankTemplate",
  "description": "Validates all fields can be read from UnitRankTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify UnitRankTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"UnitRankTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify UnitRankTemplate.1_lance_corporal exists",
      "code": "!Menace.SDK.Templates.Find(\"UnitRankTemplate\", \"1_lance_corporal\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"UnitRankTemplate\", \"1_lance_corporal\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field RankType",
      "code": "Menace.SDK.Templates.GetProperty(\"UnitRankTemplate\", \"1_lance_corporal\", \"RankType\") != null"
