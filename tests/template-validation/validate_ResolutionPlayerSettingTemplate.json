{
  "name": "Template Validation - ResolutionPlayerSettingTemplate",
  "description": "Validates all fields can be read from ResolutionPlayerSettingTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify ResolutionPlayerSettingTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"ResolutionPlayerSettingTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify ResolutionPlayerSettingTemplate.display_resolution exists",
      "code": "!Menace.SDK.Templates.Find(\"ResolutionPlayerSettingTemplate\", \"display_resolution\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ResolutionPlayerSettingTemplate\", \"display_resolution\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"ResolutionPlayerSettingTemplate\", \"display_resolution\", \"m_ID\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Name",
      "code": "Menace.SDK.Templates.GetProperty(\"ResolutionPlayerSettingTemplate\", \"display_resolution\", \"Name\") != null"
    }
  ]
}