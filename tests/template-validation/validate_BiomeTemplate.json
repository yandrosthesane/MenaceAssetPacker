{
  "name": "Template Validation - BiomeTemplate",
  "description": "Validates all fields can be read from BiomeTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify BiomeTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"BiomeTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify BiomeTemplate.biome.desert_canyon exists",
      "code": "!Menace.SDK.Templates.Find(\"BiomeTemplate\", \"biome.desert_canyon\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"BiomeTemplate\", \"biome.desert_canyon\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field BiomeType",
      "code": "Menace.SDK.Templates.GetProperty(\"BiomeTemplate\", \"biome.desert_canyon\", \"BiomeType\") != null"
    },
    {
      "type": "repl",
      "name": "Read field ShowInCheatMenu",
      "code": "Menace.SDK.Templates.GetProperty(\"BiomeTemplate\", \"biome.desert_canyon\", \"ShowInCheatMenu\") != null"
    },
    {
      "type": "repl",
      "name": "Read field HasGrass",
      "code": "Menace.SDK.Templates.GetProperty(\"BiomeTemplate\", \"biome.desert_canyon\", \"HasGrass\") != null"
    },
    {
      "type": "repl",
      "name": "Read field ElevationBlockLoS",
      "code": "Menace.SDK.Templates.GetProperty(\"BiomeTemplate\", \"biome.desert_canyon\", \"ElevationBlockLoS\") != null"
    },
    {
