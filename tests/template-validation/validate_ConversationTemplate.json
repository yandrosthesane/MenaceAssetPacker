    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify ConversationTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"ConversationTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify ConversationTemplate.0_idle_trader exists",
      "code": "!Menace.SDK.Templates.Find(\"ConversationTemplate\", \"0_idle_trader\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"ConversationTemplate\", \"0_idle_trader\", \"name\") != null"
    },
