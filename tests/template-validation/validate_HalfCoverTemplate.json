{
  "name": "Template Validation - HalfCoverTemplate",
  "description": "Validates all fields can be read from HalfCoverTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify HalfCoverTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"HalfCoverTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify HalfCoverTemplate.half_cover_default exists",
      "code": "!Menace.SDK.Templates.Find(\"HalfCoverTemplate\", \"half_cover_default\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"HalfCoverTemplate\", \"half_cover_default\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field IsBlockingMovement",
