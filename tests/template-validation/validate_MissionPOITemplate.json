{
  "name": "Template Validation - MissionPOITemplate",
  "description": "Validates all fields can be read from MissionPOITemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify MissionPOITemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"MissionPOITemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify MissionPOITemplate.mission_poi.admin_center exists",
      "code": "!Menace.SDK.Templates.Find(\"MissionPOITemplate\", \"mission_poi.admin_center\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionPOITemplate\", \"mission_poi.admin_center\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Type",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionPOITemplate\", \"mission_poi.admin_center\", \"Type\") != null"
    },
    {
      "type": "repl",
      "name": "Read field m_ID",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionPOITemplate\", \"mission_poi.admin_center\", \"m_ID\") != null"
    },
    {
      "type": "repl",
