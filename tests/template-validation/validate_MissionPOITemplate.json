      "code": "Menace.SDK.Templates.GetProperty(\"MissionPOITemplate\", \"mission_poi.admin_center\", \"DisplayDescription\") != null"
    },
    {
      "type": "repl",
      "name": "Read field HasIcon",
      "code": "Menace.SDK.Templates.GetProperty(\"MissionPOITemplate\", \"mission_poi.admin_center\", \"HasIcon\") != null"
    },
    {
