{
  "name": "Template Validation - CommodityTemplate",
  "description": "Validates all fields can be read from CommodityTemplate instances",
  "steps": [
    {
      "type": "command",
      "name": "Navigate to main menu to load templates",
      "command": "test.goto_main"
    },
    {
      "type": "wait",
      "name": "Wait for scene load",
      "durationMs": 3000
    },
    {
      "type": "repl",
      "name": "Verify CommodityTemplate templates load",
      "code": "Menace.SDK.Templates.FindAll(\"CommodityTemplate\").Length > 0"
    },
    {
      "type": "repl",
      "name": "Verify CommodityTemplate.commodity.civilian_supplies exists",
      "code": "!Menace.SDK.Templates.Find(\"CommodityTemplate\", \"commodity.civilian_supplies\").IsNull"
    },
    {
      "type": "repl",
      "name": "Read field name",
      "code": "Menace.SDK.Templates.GetProperty(\"CommodityTemplate\", \"commodity.civilian_supplies\", \"name\") != null"
    },
    {
      "type": "repl",
      "name": "Read field Rarity",
      "code": "Menace.SDK.Templates.GetProperty(\"CommodityTemplate\", \"commodity.civilian_supplies\", \"Rarity\") != null"
    },
