  "event_flow": {
    "damage_event_order": [
      "1. Attack skill calculates damage",
      "2. DamageInfo created with base values",
      "3. OnBeforeDamageReceived called on all handlers",
      "4. Handlers like IgnoreDamage, DivineIntervention, LimitMaxHpLoss modify DamageInfo",
      "5. OnDamageReceived called to apply final damage",
      "6. Handlers like TriggerSkillOnHpLost respond to damage taken"
    ],
    "key_event_codes": {
      "1000": "Regeneration/RestoreArmor (healing events)"
    }
  },
  "key_discoveries": [
    "No traditional 'Shield' or 'Barrier' classes exist - protection is implemented via individual effect handlers",
    "DivineIntervention is the closest to a shield - one-time death prevention per round",
    "IgnoreDamage provides percentage-based damage reduction with tag filtering",
    "LimitMaxHpLoss caps damage to a percentage of max HP",
    "All protection handlers work by modifying the DamageInfo struct before damage is applied",
    "Armor and HP are separate damage pools with different handlers",
    "Regeneration and RestoreArmorDurability handle healing/restoration",
    "DOT effects can target armor only or full HP+armor"
  ]
}
